{
  "name": "soccer-simulator",
  "version": "0.3.0",
  "dataSchemaVersion": "B",
  "scripts": {
    "check:data-schema-version": "node scripts/sync-data-schema-version.mjs --check",
    "sync:data-schema-version": "node scripts/sync-data-schema-version.mjs",
    "prestart": "npm run sync:data-schema-version",
    "ng": "ng",
    "start": "ng serve",
    "predev": "npm run sync:data-schema-version",
    "dev": "cross-env ng serve --port=3000 --host=0.0.0.0 --allowed-hosts",
    "prebuild": "npm run sync:data-schema-version",
    "build": "ng build",
    "build:gh-pages": "ng build --base-href ./",
    "prewatch": "npm run sync:data-schema-version",
    "watch": "ng build --watch --configuration development",
    "version:data": "node -e \"console.log(require('./package.json').dataSchemaVersion)\"",
    "pretest": "npm run sync:data-schema-version",
    "test": "ng test",
    "test:simulation-ab": "ng test --watch=false --include src/app/services/match.simulation.ab.spec.ts",
    "test:simulation-calibration": "ng test --watch=false --include src/app/services/match.simulation.variant-b.calibration.spec.ts",
    "prelint": "npm run sync:data-schema-version",
    "lint": "ng lint",
    "serve:ssr:app": "node dist/app/server/server.mjs",
    "prepare": "npm run sync:data-schema-version && husky install",
    "predeploy": "npm run build:gh-pages",
    "prepare:gh-pages": "node -e \"const fs=require('fs');const p='dist/app/browser';const html=fs.readFileSync(p+'/index.csr.html','utf8').replace('<base href=\\\"/\\\">','<base href=\\\"./\\\">');fs.writeFileSync(p+'/index.html',html);\"",
    "deploy": "npm run prepare:gh-pages && gh-pages -d dist/app/browser"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --fix --format=stylish",
      "eslint --format=stylish --max-warnings=0"
    ]
  },
  "dependencies": {
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "dexie": "^4.3.0",
    "express": "^5.1.0",
    "motion": "^12.23.24",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.0"
  }
}
